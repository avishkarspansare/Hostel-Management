    {
      "name": "Payment (Razorpay)",
      "item": [
        {
          "name": "Create Razorpay Order (Tenant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.orderId) pm.collectionVariables.set('razorpay_order_id', res.orderId);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentRecordId\": \"{{rent_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payment/create-order",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payment",
                "create-order"
              ]
            },
            "description": "Step 1 \u2014 Call this before opening the Razorpay checkout modal. Returns orderId, amount, and keyId. In the real app, the frontend uses these to open window.Razorpay."
          }
        },
        {
          "name": "Verify Payment (Tenant)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"razorpay_order_id\": \"{{razorpay_order_id}}\",\n  \"razorpay_payment_id\": \"pay_test_XXXXXXXXXXXX\",\n  \"razorpay_signature\": \"<hmac_sha256_signature>\",\n  \"rentRecordId\": \"{{rent_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/payment/verify",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "payment",
                "verify"
              ]
            },
            "description": "Step 2 \u2014 Called by the frontend after Razorpay modal returns success. Verifies the HMAC-SHA256 signature and marks rent as paid. In test mode, use the values returned by the Razorpay modal handler function."
          }
        }
      ]
